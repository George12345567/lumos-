# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# DO NOT add the Supabase service-role key here. Anything prefixed with
# VITE_ is bundled into the frontend JavaScript and shipped to every
# browser. The service role bypasses RLS — leaking it would compromise
# the entire database. Keep it server-side only (Edge Functions / CI).

# Master admin email — used as a UI gate only. Real authorization must be
# enforced by Supabase RLS policies. See SUPABASE_SECURITY_SETUP.md.
VITE_MASTER_ADMIN_EMAIL=your_admin_email@example.com

# Optional: enable the mocked /profile-preview demo route in production builds.
# Off by default; only set to "true" if you intentionally want a public demo.
# VITE_ENABLE_PROFILE_PREVIEW=true

# AI Chat — DISABLED in production.
#
# The AI chat sidebar is intentionally not mounted, and any browser-readable
# `VITE_AI_*_KEY` would be bundled into the production JS for every visitor.
# Do NOT set VITE_AI_API_KEY / VITE_AI_FALLBACK_KEY in production.
#
# To re-enable AI chat, build a server-side proxy (Supabase Edge Function or
# similar) that holds the upstream key, and call that proxy from the browser
# instead. See SUPABASE_EDGE_FUNCTIONS_TODO.md for the pattern.
