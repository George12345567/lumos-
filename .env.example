# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Master Admin Email (for hardcoded admin access)
VITE_MASTER_ADMIN_EMAIL=your_admin_email@example.com

# EmailJS Configuration
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here

# AI Chat Configuration (Primary: OpenRouter)
VITE_AI_API_KEY=your_openrouter_api_key_here
VITE_AI_API_ENDPOINT=https://openrouter.ai/api/v1
VITE_AI_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# AI Chat Fallback (AgentRouter)
VITE_AI_FALLBACK_KEY=your_agentrouter_api_key_here
VITE_AI_FALLBACK_ENDPOINT=https://agentrouter.org/v1
VITE_AI_FALLBACK_MODEL=glm-5-1
